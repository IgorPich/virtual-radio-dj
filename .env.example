# ─── Spotify OAuth ───────────────────────────────────────────────────────────
SPOTIFY__CLIENT_ID=your_spotify_client_id_here
SPOTIFY__CLIENT_SECRET=your_spotify_client_secret_here
# Redirect URI registered in your Spotify app dashboard
SPOTIFY__REDIRECT_URI=http://localhost:8888/callback

# ─── LLM (Ollama) ────────────────────────────────────────────────────────────
LLM__ENDPOINT=http://localhost:11434
LLM__MODEL=mistral
LLM__TEMPERATURE=0.8
LLM__TIMEOUT_SEC=60

# ─── TTS ─────────────────────────────────────────────────────────────────────
# Options: local_gtts | elevenlabs | piper
TTS__PROVIDER=local_gtts
TTS__LANGUAGE=en
TTS__SLOW=false
TTS__COHOST_NAME=Emma

# ElevenLabs settings (only used when TTS__PROVIDER=elevenlabs)
TTS__ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TTS__ELEVENLABS_VOICE_ID=your_voice_id_here
TTS__ELEVENLABS_MODEL=eleven_turbo_v2_5

# ─── DJ Behaviour ────────────────────────────────────────────────────────────
# The DJ speaks once every N songs, randomised between min and max each time.
DJ__SONG_INTERVAL_MIN=2
DJ__SONG_INTERVAL_MAX=4
# If a track is skipped before this many seconds, suppress the DJ entirely.
# If skipped after this threshold, trigger the DJ immediately.
DJ__SKIP_GRACE_PERIOD_SEC=60.0

# ─── Audio Ducking ────────────────────────────────────────────────────────────
AUDIO__SPOTIFY_PROCESS_NAME=Spotify.exe
AUDIO__DUCK_TARGET_VOLUME=0.25
AUDIO__DUCK_IN_MS=600
AUDIO__DUCK_OUT_MS=900
AUDIO__TAIL_SILENCE_MS=300

# ─── Spotify polling ─────────────────────────────────────────────────────────
SPOTIFY__POLL_INTERVAL_SEC=1.0
SPOTIFY__TRIGGER_BEFORE_END_SEC=20.0

# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
API__HOST=127.0.0.1
API__PORT=5000
